---
// Place at: src/pages/index.astro (replaces the stock "Hello, Astronaut")
// Designed brand landing: featured "today", browse by mood, browse by day
// (the high-volume axis), and a recent strip. Not an endless feed.
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { HUBS, DAY_HUBS } from '../hubs';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = posts[0];
const recent = posts.slice(1, 7);
const themeRep = (hub) => posts.find((p) => hub.themes.includes(p.data.theme));
const dayRep = (hub) => posts.find((p) => DAYS[p.data.pubDate.getUTCDay()] === hub.weekday);
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="hero-text">
          <h1>A fresh good morning, every day.</h1>
          <p>Original hand-drawn good morning pictures — a new one each morning, for every day of the week.</p>
        </div>
        {featured && (
          <a href={`/blog/${featured.id}/`} class="hero-img">
            <img src={featured.data.heroImage} alt={featured.data.title} />
            <span>Today &middot; {featured.data.title}</span>
          </a>
        )}
      </section>

      <section>
        <h2>Browse by mood</h2>
        <div class="tiles">
          {HUBS.map((hub) => {
            const rep = themeRep(hub);
            return (
              <a href={`/${hub.slug}/`} class="tile">
                {rep ? <img src={rep.data.heroImage} alt={hub.title} loading="lazy" /> : <div class="ph"></div>}
                <span>{hub.title}</span>
              </a>
            );
          })}
        </div>
      </section>

      <section>
        <h2>Browse by day</h2>
        <div class="tiles">
          {DAY_HUBS.map((hub) => {
            const rep = dayRep(hub);
            return (
              <a href={`/${hub.slug}/`} class="tile">
                {rep ? <img src={rep.data.heroImage} alt={hub.title} loading="lazy" /> : <div class="ph"></div>}
                <span>{hub.weekday}</span>
              </a>
            );
          })}
        </div>
      </section>

      {recent.length > 0 && (
        <section>
          <h2>Recent mornings</h2>
          <div class="tiles">
            {recent.map((p) => (
              <a href={`/blog/${p.id}/`} class="card">
                <img src={p.data.heroImage} alt={p.data.title} loading="lazy" />
                <span>{p.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  main { width: 1000px; max-width: calc(100% - 2em); margin: auto; padding: 2em 1em; }
  h2 { margin: 2.5em 0 1em; }

  .hero { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2em; align-items: center; }
  .hero-text h1 { margin: 0 0 0.5em; line-height: 1.1; }
  .hero-text p { color: rgb(var(--gray)); font-size: 1.1em; max-width: 40ch; }
  .hero-img { display: block; text-decoration: none; color: inherit; }
  .hero-img img {
    width: 100%; aspect-ratio: 2 / 3; object-fit: cover;
    border-radius: 16px; box-shadow: var(--box-shadow);
  }
  .hero-img span { display: block; margin-top: 0.5em; color: rgb(var(--gray)); font-size: 0.95em; }

  .tiles { display: grid; gap: 1.1em; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  .tile { display: block; text-decoration: none; color: inherit; text-align: center; }
  .tile img, .ph {
    width: 100%; aspect-ratio: 2 / 3; object-fit: cover;
    border-radius: 12px; box-shadow: var(--box-shadow);
  }
  .ph { background: rgb(var(--gray-light)); }
  .tile span { display: block; margin-top: 0.5em; font-weight: 600; font-size: 0.92em; }

  .card { display: block; text-decoration: none; color: inherit; }
  .card img {
    width: 100%; aspect-ratio: 2 / 3; object-fit: cover;
    border-radius: 12px; box-shadow: var(--box-shadow);
  }
  .card span { display: block; margin-top: 0.4em; font-size: 0.9em; }

  @media (max-width: 720px) { .hero { grid-template-columns: 1fr; } }
</style>
