---
// Place at: src/pages/about.astro (replaces the stock file)
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About Good Morning Pics — a fresh, original good morning drawing every day." />
	</head>
	<body>
		<Header />
		<main>
			<h1>About Good Morning Pics</h1>
			<p>
				Good Morning Pics is a fresh, original drawing every single morning — a small
				piece of sunshine to start the day. Every image is made by hand in a warm,
				retro style, with a new one for every day of the week.
			</p>
			<p>
				The idea is simple: a good morning is worth sharing. Whether you're after a
				cozy coffee scene, a calm sunrise, or a little Monday motivation, there's a
				picture here to send to someone you care about — or just to enjoy yourself.
			</p>
			<p>
				New art posts daily. Follow along on Pinterest, or
				<a href="/">browse the latest mornings here</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { width: 720px; max-width: calc(100% - 2em); margin: auto; padding: 2em 1em; }
	h1 { margin: 0 0 0.5em; }
	p { color: rgb(var(--gray-dark)); line-height: 1.7; }
</style>
