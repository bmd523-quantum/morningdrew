---
// Place at: src/components/Header.astro (replaces the stock file)
// Title pulls from SITE_TITLE so it reads "Good Morning Pics". The stock
// Astro social icons are removed; nav kept simple.
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/coffee/">Coffee</HeaderLink>
			<HeaderLink href="/sunrise/">Sunrise</HeaderLink>
			<HeaderLink href="/about/">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 { margin: 0; font-size: 1em; }
	h2 a, h2 a.active { text-decoration: none; }
	nav {
		display: flex; align-items: center; justify-content: space-between;
		max-width: 1000px; margin: 0 auto;
	}
	nav a { padding: 1em 0.5em; color: var(--black); text-decoration: none; }
	.internal-links { display: flex; gap: 0.25em; flex-wrap: wrap; }
	@media (max-width: 720px) {
		nav { flex-direction: column; gap: 0.25em; padding: 0.5em 0; }
	}
</style>
