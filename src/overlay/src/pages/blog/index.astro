---
// Place at: src/pages/blog/index.astro (replaces the stock file)
// IMPORTANT: the stock version uses Astro's <Image> with an image() hero.
// Since heroImage is now a string path under /public, it must use a plain
// <img> — otherwise the build errors.
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<html lang="en">
	<head>
		<BaseHead title={`All Mornings | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Every morning</h1>
			<section>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
								<h4 class="title">{post.data.title}</h4>
								<p class="date"><FormattedDate date={post.data.pubDate} /></p>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { width: 960px; max-width: calc(100% - 2em); margin: auto; padding: 2em 1em; }
	ul {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1.5em; list-style: none; margin: 0; padding: 0;
	}
	ul li a { display: block; text-decoration: none; color: inherit; }
	ul li img {
		width: 100%; aspect-ratio: 2 / 3; object-fit: cover;
		border-radius: 12px; box-shadow: var(--box-shadow);
	}
	.title { margin: 0.5em 0 0; font-size: 1em; }
	.date { margin: 0; color: rgb(var(--gray)); font-size: 0.9em; }
</style>
