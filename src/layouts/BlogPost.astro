---
// Place at: src/layouts/BlogPost.astro (replaces the stock file)
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { THEME_BRAND, THEME_CTA, BRANDS } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, theme } = Astro.props;
const brandKey = THEME_BRAND[theme];
const brand = brandKey ? BRANDS[brandKey] : null;
const cta = THEME_CTA[theme];
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const imageUrl = new URL(heroImage, Astro.site).href;
const downloadName = heroImage.split('/').pop();
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} type="article" />
		<style>
			main { width: calc(100% - 2em); max-width: 100%; margin: 0; }
			.hero-image { width: 100%; }
			.hero-image img {
				display: block; margin: 0 auto; max-width: 480px; width: 100%;
				border-radius: 12px; box-shadow: var(--box-shadow);
			}
			.share-wrap {
				width: 720px; max-width: calc(100% - 2em);
				margin: 0 auto; padding: 0 1em;
			}
			.prose {
				width: 720px; max-width: calc(100% - 2em);
				margin: auto; padding: 1em; color: rgb(var(--gray-dark));
			}
			.title { margin-bottom: 1em; padding: 1em 0; text-align: center; line-height: 1; }
			.title h1 { margin: 0 0 0.5em 0; }
			.date { margin-bottom: 0.5em; color: rgb(var(--gray)); }
			.last-updated-on { font-style: italic; }
			.brand-link { margin-top: 2em; text-align: center; font-weight: 600; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img src={heroImage} alt={title} width="1000" height="1500" />}
				</div>
				<div class="share-wrap">
					<ShareButtons
						pageUrl={pageUrl}
						imageUrl={imageUrl}
						title={title}
						description={description}
						downloadName={downloadName}
					/>
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<div class="last-updated-on">Last updated on <FormattedDate date={updatedDate} /></div>
							)}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
					{brand && (
						<p class="brand-link">
							<a href={brand.url} rel="noopener">{cta} → {brand.name}</a>
						</p>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
